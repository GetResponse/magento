parameters:
	ignoreErrors:
		-
			message: "#^Parameter \\$quoteFactory of method GetResponse\\\\GetResponseIntegration\\\\Controller\\\\Cart\\\\AbandonedCart\\:\\:__construct\\(\\) has invalid type Magento\\\\Quote\\\\Model\\\\QuoteFactory\\.$#"
			count: 1
			path: Controller/Cart/AbandonedCart.php

		-
			message: "#^Method GetResponse\\\\GetResponseIntegration\\\\Extensions\\\\Customer\\:\\:afterGetExtensionAttributes\\(\\) has invalid return type Magento\\\\Customer\\\\Api\\\\Data\\\\CustomerExtensionInterface\\.$#"
			count: 1
			path: Extensions/Customer.php

		-
			message: "#^Parameter \\$extension of method GetResponse\\\\GetResponseIntegration\\\\Extensions\\\\Customer\\:\\:afterGetExtensionAttributes\\(\\) has invalid type Magento\\\\Customer\\\\Api\\\\Data\\\\CustomerExtensionInterface\\.$#"
			count: 1
			path: Extensions/Customer.php

		-
			message: "#^Parameter \\$extensionFactory of method GetResponse\\\\GetResponseIntegration\\\\Extensions\\\\Customer\\:\\:__construct\\(\\) has invalid type Magento\\\\Customer\\\\Api\\\\Data\\\\CustomerExtensionFactory\\.$#"
			count: 1
			path: Extensions/Customer.php

		-
			message: "#^Class Magento\\\\Csp\\\\Helper\\\\CspNonceProvider not found\\.$#"
			count: 1
			path: Helper/CspNonceProviderFactory.php

		-
			message: "#^Method GetResponse\\\\GetResponseIntegration\\\\Helper\\\\CspNonceProviderFactory\\:\\:create\\(\\) has invalid return type Magento\\\\Csp\\\\Helper\\\\CspNonceProvider\\.$#"
			count: 1
			path: Helper/CspNonceProviderFactory.php

		-
			message: "#^Method GetResponse\\\\GetResponseIntegration\\\\Logger\\\\Logger\\:\\:addError\\(\\) should return bool but return statement is missing\\.$#"
			count: 1
			path: Logger/Logger.php

		-
			message: "#^Method GetResponse\\\\GetResponseIntegration\\\\Logger\\\\Logger\\:\\:addNotice\\(\\) should return bool but return statement is missing\\.$#"
			count: 1
			path: Logger/Logger.php

		-
			message: "#^Class Magento\\\\Customer\\\\Model\\\\ResourceModel\\\\Address\\\\Attribute\\\\Collection constructor invoked with 0 parameters, 6\\-8 required\\.$#"
			count: 1
			path: Test/MissingReferences/Magento/Customer/Model/ResourceModel/Address/Attribute/CollectionFactory.php

		-
			message: "#^Class Magento\\\\Customer\\\\Model\\\\ResourceModel\\\\Attribute\\\\Collection constructor invoked with 0 parameters, 6\\-8 required\\.$#"
			count: 1
			path: Test/MissingReferences/Magento/Customer/Model/ResourceModel/Attribute/CollectionFactory.php

		-
			message: "#^Class Magento\\\\Newsletter\\\\Model\\\\ResourceModel\\\\Subscriber\\\\Collection constructor invoked with 0 parameters, 5\\-7 required\\.$#"
			count: 1
			path: Test/MissingReferences/Newsletter/Model/ResourceModel/Subscriber/CollectionFactory.php

